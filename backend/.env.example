# Email Configuration for Gmail
# Get App Password from: https://myaccount.google.com/apppasswords

# SMTP Server (Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address (sender)
SENDER_EMAIL=your-email@gmail.com

# Gmail App Password (NOT your regular password!)
# Generate at: https://myaccount.google.com/apppasswords
SENDER_PASSWORD=your-16-character-app-password

# Email address where you want to receive orders
RECEIVER_EMAIL=ashifnihal2012@gmail.com

# Razorpay Payment Gateway Configuration (UPI Only)
# Sign up at: https://razorpay.com
# Get keys from: Dashboard > Settings > API Keys

# Razorpay Key ID (Test or Live)
RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Razorpay Key Secret (Test or Live)
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
