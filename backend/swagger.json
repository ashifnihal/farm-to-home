{
  "openapi": "3.0.0",
  "info": {
    "title": "Farm to Home API",
    "description": "Complete API documentation for Farm to Home - Premium Mango Delivery Platform. This API provides endpoints for order management, payment processing, user authentication, and admin operations.",
    "version": "2.0.0",
    "contact": {
      "name": "Farm to Home Support",
      "email": "ashifnihal2012@gmail.com",
      "url": "https://github.com/ashifnihal/farm-to-home"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5001",
      "description": "Development server"
    },
    {
      "url": "https://farm-to-home-api.onrender.com",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health check endpoints"
    },
    {
      "name": "Orders",
      "description": "Order management endpoints"
    },
    {
      "name": "Payment",
      "description": "Payment processing endpoints"
    },
    {
      "name": "Contacts",
      "description": "Contact form endpoints"
    },
    {
      "name": "Users",
      "description": "User authentication and management"
    },
    {
      "name": "Statistics",
      "description": "Admin statistics endpoints"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Check if the API server is running and healthy",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2026-03-30T22:45:00+05:30"
                    },
                    "database": {
                      "type": "string",
                      "example": "postgres"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/place-order": {
      "post": {
        "tags": ["Orders"],
        "summary": "Place a new order",
        "description": "Create a new order with customer details, items, and payment information",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order placed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get all orders",
        "description": "Retrieve all orders with customer details (Admin only)",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of orders to return",
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "orders": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Order"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order details",
        "description": "Retrieve detailed information about a specific order",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Order ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "order": {
                      "$ref": "#/components/schemas/OrderDetails"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Order not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/create-payment-order": {
      "post": {
        "tags": ["Payment"],
        "summary": "Create Razorpay payment order",
        "description": "Create a new Razorpay order for payment processing",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount"],
                "properties": {
                  "amount": {
                    "type": "number",
                    "description": "Order amount in INR",
                    "example": 2500
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment order created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "order_id": {
                      "type": "string",
                      "example": "order_NXZvKqJ8xYZvKq"
                    },
                    "amount": {
                      "type": "number",
                      "example": 250000
                    },
                    "currency": {
                      "type": "string",
                      "example": "INR"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/verify-payment": {
      "post": {
        "tags": ["Payment"],
        "summary": "Verify Razorpay payment",
        "description": "Verify payment signature from Razorpay",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["razorpay_order_id", "razorpay_payment_id", "razorpay_signature"],
                "properties": {
                  "razorpay_order_id": {
                    "type": "string",
                    "example": "order_NXZvKqJ8xYZvKq"
                  },
                  "razorpay_payment_id": {
                    "type": "string",
                    "example": "pay_NXZvKqJ8xYZvKq"
                  },
                  "razorpay_signature": {
                    "type": "string",
                    "example": "9ef4dffbfd84f1318f6739a3ce19f9d85851857ae648f114332d8401e0949a3d"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment verified",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Payment verified successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid signature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/contact": {
      "post": {
        "tags": ["Contacts"],
        "summary": "Submit contact form",
        "description": "Submit a contact enquiry",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact form submitted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Thank you for contacting us!"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/contacts": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get all contacts",
        "description": "Retrieve all contact form submissions (Admin only)",
        "responses": {
          "200": {
            "description": "List of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "contacts": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Contact"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/register": {
      "post": {
        "tags": ["Users"],
        "summary": "Register new user",
        "description": "Create a new user account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Registration successful!"
                    },
                    "user_id": {
                      "type": "integer",
                      "example": 1
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Email already registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/login": {
      "post": {
        "tags": ["Users"],
        "summary": "User login",
        "description": "Authenticate user and create session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "user@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "SecurePassword123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Login successful!"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Get all users",
        "description": "Retrieve all registered users (Admin only)",
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "users": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/User"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/statistics": {
      "get": {
        "tags": ["Statistics"],
        "summary": "Get statistics",
        "description": "Retrieve platform statistics (Admin only)",
        "responses": {
          "200": {
            "description": "Platform statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Statistics"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OrderRequest": {
        "type": "object",
        "required": ["customer", "items", "total", "payment", "orderDate"],
        "properties": {
          "customer": {
            "$ref": "#/components/schemas/Customer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          },
          "total": {
            "type": "number",
            "example": 2500
          },
          "payment": {
            "type": "string",
            "enum": ["upi", "razorpay", "cod"],
            "example": "upi"
          },
          "upi_id": {
            "type": "string",
            "example": "user@paytm"
          },
          "razorpay_order_id": {
            "type": "string",
            "example": "order_NXZvKqJ8xYZvKq"
          },
          "razorpay_payment_id": {
            "type": "string",
            "example": "pay_NXZvKqJ8xYZvKq"
          },
          "orderDate": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-30T22:45:00+05:30"
          }
        }
      },
      "Customer": {
        "type": "object",
        "required": ["name", "email", "phone", "address", "city", "pincode"],
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "phone": {
            "type": "string",
            "example": "+91 9876543210"
          },
          "house": {
            "type": "string",
            "example": "123, Apartment Name"
          },
          "street": {
            "type": "string",
            "example": "MG Road"
          },
          "landmark": {
            "type": "string",
            "example": "Near Metro Station"
          },
          "address": {
            "type": "string",
            "example": "123, MG Road, Bangalore"
          },
          "city": {
            "type": "string",
            "example": "Bangalore"
          },
          "state": {
            "type": "string",
            "example": "Karnataka"
          },
          "pincode": {
            "type": "string",
            "example": "560001"
          },
          "country": {
            "type": "string",
            "example": "India"
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "required": ["name", "price", "quantity"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Alphonso Mango - 1kg"
          },
          "price": {
            "type": "number",
            "example": 500
          },
          "quantity": {
            "type": "integer",
            "example": 2
          },
          "type": {
            "type": "string",
            "enum": ["mango", "tree"],
            "example": "mango"
          }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Order placed successfully!"
          },
          "order_id": {
            "type": "integer",
            "example": 1
          },
          "order_number": {
            "type": "string",
            "example": "FTH20260330224500"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "order_number": {
            "type": "string",
            "example": "FTH20260330224500"
          },
          "order_type": {
            "type": "string",
            "enum": ["mango", "tree"],
            "example": "mango"
          },
          "customer_name": {
            "type": "string",
            "example": "John Doe"
          },
          "customer_email": {
            "type": "string",
            "example": "john@example.com"
          },
          "customer_phone": {
            "type": "string",
            "example": "+91 9876543210"
          },
          "total_amount": {
            "type": "number",
            "example": 2500
          },
          "payment_method": {
            "type": "string",
            "example": "upi"
          },
          "order_status": {
            "type": "string",
            "enum": ["placed", "confirmed", "delivered", "cancelled"],
            "example": "placed"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-30T22:45:00"
          }
        }
      },
      "OrderDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Order"
          },
          {
            "type": "object",
            "properties": {
              "address": {
                "type": "string",
                "example": "123, MG Road, Bangalore"
              },
              "city": {
                "type": "string",
                "example": "Bangalore"
              },
              "pincode": {
                "type": "string",
                "example": "560001"
              },
              "house": {
                "type": "string",
                "example": "123, Apartment Name"
              },
              "street": {
                "type": "string",
                "example": "MG Road"
              },
              "landmark": {
                "type": "string",
                "example": "Near Metro Station"
              },
              "state": {
                "type": "string",
                "example": "Karnataka"
              },
              "country": {
                "type": "string",
                "example": "India"
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "item_name": {
                      "type": "string",
                      "example": "Alphonso Mango - 1kg"
                    },
                    "item_type": {
                      "type": "string",
                      "example": "mango"
                    },
                    "quantity": {
                      "type": "integer",
                      "example": 2
                    },
                    "price": {
                      "type": "number",
                      "example": 500
                    },
                    "subtotal": {
                      "type": "number",
                      "example": 1000
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "ContactRequest": {
        "type": "object",
        "required": ["name", "email", "message"],
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "phone": {
            "type": "string",
            "example": "+91 9876543210"
          },
          "message": {
            "type": "string",
            "example": "I would like to know more about your products."
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "phone": {
            "type": "string",
            "example": "+91 9876543210"
          },
          "message": {
            "type": "string",
            "example": "I would like to know more about your products."
          },
          "status": {
            "type": "string",
            "enum": ["new", "contacted", "resolved"],
            "example": "new"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-30T22:45:00"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["name", "email", "phone", "address", "city", "pincode", "password"],
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "phone": {
            "type": "string",
            "example": "+91 9876543210"
          },
          "address": {
            "type": "string",
            "example": "123, MG Road"
          },
          "city": {
            "type": "string",
            "example": "Bangalore"
          },
          "pincode": {
            "type": "string",
            "example": "560001"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "SecurePassword123"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "phone": {
            "type": "string",
            "example": "+91 9876543210"
          },
          "address": {
            "type": "string",
            "example": "123, MG Road"
          },
          "city": {
            "type": "string",
            "example": "Bangalore"
          },
          "pincode": {
            "type": "string",
            "example": "560001"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-30T22:45:00"
          },
          "last_login": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-30T22:45:00"
          }
        }
      },
      "Statistics": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "statistics": {
            "type": "object",
            "properties": {
              "total_orders": {
                "type": "integer",
                "example": 150
              },
              "total_customers": {
                "type": "integer",
                "example": 120
              },
              "total_revenue": {
                "type": "number",
                "example": 375000
              },
              "total_contacts": {
                "type": "integer",
                "example": 45
              },
              "orders_by_status": {
                "type": "object",
                "properties": {
                  "placed": {
                    "type": "integer",
                    "example": 30
                  },
                  "confirmed": {
                    "type": "integer",
                    "example": 80
                  },
                  "delivered": {
                    "type": "integer",
                    "example": 35
                  },
                  "cancelled": {
                    "type": "integer",
                    "example": 5
                  }
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "example": "Invalid request data"
          },
          "message": {
            "type": "string",
            "example": "Please provide all required fields"
          }
        }
      }
    }
  }
}